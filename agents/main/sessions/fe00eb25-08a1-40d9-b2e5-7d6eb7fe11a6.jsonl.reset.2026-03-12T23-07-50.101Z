ef=e109]:\n          - button \"Files\" [ref=e110] [cursor=pointer]\n          - button \"Compare\" [ref=e111] [cursor=pointer]\n          - button \"Versions\" [ref=e112] [cursor=pointer]\n        - generic [ref=e113]:\n          - generic [ref=e114]:\n            - heading \"SKILL.md\" [level=2] [ref=e115]\n            - generic [ref=e116]:\n              - heading \"MiniMax Music Maker\" [level=1] [ref=e117]\n              - paragraph [ref=e118]:\n                - text: Use this skill to generate music with MiniMax's Music Generation API. All usage and outputs are designed for\n                - strong [ref=e119]: music-2.5\n                - text: unless specified otherwise.\n              - heading \"Quick start\" [level=2] [ref=e120]\n              - list [ref=e121]:\n                - listitem [ref=e122]: \"Set the API key:\"\n              - code [ref=e124]: export MINIMAX_MUSIC_API_KEY=\"your_api_key\"\n              - list [ref=e125]:\n                - listitem [ref=e126]: \"Generate music from lyrics (and optional prompt):\"\n              - code [ref=e128]: python scripts/generate_music.py \\ --lyrics \"[Verse]\\n...\\n[Chorus]\\n...\" \\ --prompt \"indie folk, melancholic, introspective\" \\ --output ./output.mp3\n              - heading \"Script location\" [level=2] [ref=e129]\n              - list [ref=e130]:\n                - listitem [ref=e131]:\n                  - code [ref=e132]: scripts/generate_music.py\n                  - text: — main generator (lyrics + prompt → audio)\n                - listitem [ref=e133]:\n                  - code [ref=e134]: scripts/utils_audio.py\n                  - text: — hex decoding + save helpers\n              - heading \"References\" [level=2] [ref=e135]\n              - paragraph [ref=e136]:\n                - text: Read\n                - strong [ref=e137]: references/minimax_music_api.md\n                - text: \"for:\"\n              - list [ref=e138]:\n                - listitem [ref=e139]: Endpoint, auth header, payload schema\n                - listitem [ref=e140]: Required/optional fields\n                - listitem [ref=e141]: Output formats (hex/url) and constraints\n              - heading \"Core Modes\" [level=2] [ref=e142]\n              - paragraph [ref=e143]:\n                - text: This skill supports\n                - strong [ref=e144]: 3 generation modes\n                - text: \":\"\n              - heading \"1. Standard Song (with lyrics)\" [level=3] [ref=e145]\n              - list [ref=e146]:\n                - listitem [ref=e147]: User provides or wants lyrics + music\n                - listitem [ref=e148]: Use structured lyrics with prompt for style\n              - heading \"2. Pure Music (Instrumental)\" [level=3] [ref=e149]\n              - list [ref=e150]:\n                - listitem [ref=e151]: \"User requests: \\\"纯音乐\\\", \\\"纯音乐，无人声\\\", \\\"pure music\\\", \\\"instrumental\\\"\"\n                - listitem [ref=e152]: No lyrics, just instrumental arrangement\n                - listitem [ref=e153]: See \"Pure Music Generation\" section below\n              - heading \"3. Melodic Chanting/Humming\" [level=3] [ref=e154]\n              - list [ref=e155]:\n                - listitem [ref=e156]: \"User requests: \\\"哼唱\\\", \\\"吟唱\\\", \\\"humming\\\", \\\"chanting\\\"\"\n                - listitem [ref=e157]: Music with vocal syllables instead of full lyrics\n                - listitem [ref=e158]: See \"Melodic Chanting Generation\" section below\n              - heading \"Notes\" [level=2] [ref=e159]\n              - list [ref=e160]:\n                - listitem [ref=e161]:\n                  - code [ref=e162]: lyrics\n                  - text: is\n                  - strong [ref=e163]: required\n                  - text: by the API.\n                - listitem [ref=e164]:\n                  - code [ref=e165]: prompt\n                  - text: is optional for\n                  - code [ref=e166]: music-2.5\n                  - text: .\n                - listitem [ref=e167]:\n                  - code [ref=e168]: output_format\n                  - text: defaults to\n                  - code [ref=e169]: hex\n                  - text: (inline audio). Use\n                  - code [ref=e170]: url\n                  - text: if you prefer a download URL.\n                - listitem [ref=e171]:\n                  - text: URLs expire (24h). Download immediately if using\n                  - code [ref=e172]: url\n                  - text: .\n              - heading \"Prompt crafting (Important)\" [level=2] [ref=e173]\n              - paragraph [ref=e174]:\n                - strong [ref=e175]: Core Principles\n                - text: \": Use \\\"descriptions\\\" instead of \\\"commands\\\", keep it structured, clear, and parseable.\"\n              - heading \"Required Elements (Recommended)\" [level=3] [ref=e176]\n              - list [ref=e177]:\n                - listitem [ref=e178]:\n                  - strong [ref=e179]: Genre/Subgenre\n                  - text: (with era or region)\n                - listitem [ref=e180]:\n                  - strong [ref=e181]: Mood/Emotion\n                  - text: (2-3 emotional descriptors)\n                - listitem [ref=e182]:\n                  - strong [ref=e183]: Tempo/BPM\n                  - text: (specify BPM if possible)\n                - listitem [ref=e184]:\n                  - strong [ref=e185]: Key Instruments\n                  - text: (3-5 key instruments/timbres)\n                - listitem [ref=e186]:\n                  - strong [ref=e187]: Vocals\n                  - text: (vocal type, processing, or instrumental)\n                - listitem [ref=e188]:\n                  - strong [ref=e189]: Use case\n                  - text: (purpose/scene)\n              - heading \"Optional Enhancements\" [level=3] [ref=e190]\n              - list [ref=e191]:\n                - listitem [ref=e192]:\n                  - strong [ref=e193]: Structure\n                  - text: (section structure)\n                - listitem [ref=e194]:\n                  - strong [ref=e195]: References\n                  - text: (1-2 style references)\n                - listitem [ref=e196]:\n                  - strong [ref=e197]: Avoid/Negative\n                  - text: (exclusions)\n              - heading \"Prompt Templates\" [level=3] [ref=e198]\n              - paragraph [ref=e199]:\n                - strong [ref=e200]: Basic Template (Beginner)\n              - code [ref=e202]: \"[Genre], [Mood], [Tempo/BPM], [Key Instruments], [Vocal Style]\"\n              - paragraph [ref=e203]:\n                - strong [ref=e204]: Standard Template (Recommended)\n              - code [ref=e206]: \"Genre: [Specific genre + era] Mood: [2-3 descriptors] Tempo: [BPM or speed] Instruments: [3-5 key instruments] Vocals: [Type or instrumental only] Use case: [scene/usage] Avoid: [unwanted elements] References: [1-2 artists/songs]\"\n              - paragraph [ref=e207]:\n                - strong [ref=e208]: Advanced Template (Production Brief)\n              - code [ref=e210]: \"Genre: … | Era: … BPM: … | Key: … Mood: ... (can include emotional arc, e.g., \\\"from restrained to explosive\\\") Lead: … Rhythm: … Bass: … Texture: … Vocals: … Structure: Intro / Verse / Chorus / Bridge / Outro Avoid: … Reference: …\"\n              - heading \"Structure Tags (in lyrics)\" [level=3] [ref=e211]\n              - code [ref=e213]: \"[Intro] [Verse] [Pre-Chorus] [Chorus] [Bridge] [Outro] [Instrumental]\"\n              - heading \"Negative Prompt Examples\" [level=3] [ref=e214]\n              - list [ref=e215]:\n                - listitem [ref=e216]:\n                  - code [ref=e217]: No vocals\n                  - text: /\n                  - code [ref=e218]: Instrumental only\n                - listitem [ref=e219]:\n                  - code [ref=e220]: Avoid autotune\n                - listitem [ref=e221]:\n                  - code [ref=e222]: No distorted guitars\n                - listitem [ref=e223]:\n                  - code [ref=e224]: Avoid heavy reverb\n                - listitem [ref=e225]:\n                  - code [ref=e226]: No trap hi-hats\n              - heading \"Common Issue Fixes\" [level=3] [ref=e227]\n              - list [ref=e228]:\n                - listitem [ref=e229]:\n                  - strong [ref=e230]: Style inaccurate\n                  - text: \": Add \\\"era + sub-genre + instrument anchors + reference artists\\\"\"\n                - listitem [ref=e231]:\n                  - strong [ref=e232]: Rhythm wrong\n                  - text: \": Specify BPM + rhythm description (e.g., four-on-the-floor)\"\n                - listitem [ref=e233]:\n                  - strong [ref=e234]: Intro too generic\n                  - text: \": Write [Intro] in lyrics and describe the opening\"\n                - listitem [ref=e235]:\n                  - strong [ref=e236]: Vocals off\n                  - text: \": Move Vocals to front of prompt and add negative constraints\"\n              - heading \"Prompt Quality Checklist\" [level=2] [ref=e237]\n              - list [ref=e238]:\n                - listitem [ref=e239]: \"Contains: Genre / Mood / BPM / Instruments / Vocals / Use case\"\n                - listitem [ref=e240]: Check for conflicts (e.g., \"very slow + high energy\")\n                - listitem [ref=e241]: Has Avoid items to filter unwanted elements\n                - listitem [ref=e242]: Is structured (avoid long prose paragraphs)\n              - separator [ref=e243]\n              - heading \"Pure Music Generation\" [level=2] [ref=e244]\n              - paragraph [ref=e245]:\n                - text: Use this mode when user wants instrumental tracks\n                - strong [ref=e246]: without lyrics\n                - text: .\n              - heading \"Detection Keywords\" [level=3] [ref=e247]\n              - list [ref=e248]:\n                - listitem [ref=e249]: 纯音乐、纯音乐无人声、无人声\n                - listitem [ref=e250]: pure music、instrumental、no lyrics\n                - listitem [ref=e251]: 背景音乐、轻音乐、器乐\n                - listitem [ref=e252]: 无歌词\n              - heading \"Prompt Format\" [level=3] [ref=e253]\n              - code [ref=e255]: pure music, [scene/style description], no lyrics\n              - heading \"Lyrics Field\" [level=3] [ref=e256]\n              - paragraph [ref=e257]:\n                - text: \"Use placeholder tags:\"\n                - code [ref=e258]: \"[intro] [outro]\"\n              - heading \"Important Notes\" [level=3] [ref=e259]\n              - paragraph [ref=e260]:\n                - text: ⚠️\n                - strong [ref=e261]: Duration\n                - text: \": Pure music tracks are typically\"\n                - strong [ref=e262]: shorter (1-2 minutes)\n                - text: because there's no lyrics to guide the musical progression.\n              - heading \"Pure Music Prompt Examples\" [level=3] [ref=e263]\n              - table [ref=e264]:\n                - rowgroup [ref=e265]:\n                  - row \"# Prompt Scene\" [ref=e266]:\n                    - columnheader \"#\" [ref=e267]\n                    - columnheader \"Prompt\" [ref=e268]\n                    - columnheader \"Scene\" [ref=e269]\n                - rowgroup [ref=e270]:\n                  - row \"1 pure music, coffee shop, no lyrics 咖啡馆氛围\" [ref=e271]:\n                    - cell \"1\" [ref=e272]\n                    - cell \"pure music, coffee shop, no lyrics\" [ref=e273]\n                    - cell \"咖啡馆氛围\" [ref=e274]\n                  - row \"2 pure music, rainy night, no lyrics 雨夜\" [ref=e275]:\n                    - cell \"2\" [ref=e276]\n                    - cell \"pure music, rainy night, no lyrics\" [ref=e277]\n                    - cell \"雨夜\" [ref=e278]\n                  - row \"3 pure music, morning sunshine, no lyrics 晨光\" [ref=e279]:\n                    - cell \"3\" [ref=e280]\n                    - cell \"pure music, morning sunshine, no lyrics\" [ref=e281]\n                    - cell \"晨光\" [ref=e282]\n                  - row \"4 pure music, jazz bar, no lyrics 爵士酒吧\" [ref=e283]:\n                    - cell \"4\" [ref=e284]\n                    - cell \"pure music, jazz bar, no lyrics\" [ref=e285]\n                    - cell \"爵士酒吧\" [ref=e286]\n                  - row \"5 pure music, city walk, no lyrics 城市漫步\" [ref=e287]:\n                    - cell \"5\" [ref=e288]\n                    - cell \"pure music, city walk, no lyrics\" [ref=e289]\n                    - cell \"城市漫步\" [ref=e290]\n                  - row \"6 pure music, night drive, no lyrics 夜间驾驶\" [ref=e291]:\n                    - cell \"6\" [ref=e292]\n                    - cell \"pure music, night drive, no lyrics\" [ref=e293]\n                    - cell \"夜间驾驶\" [ref=e294]\n                  - row \"7 pure music, piano solo, no lyrics 钢琴独奏\" [ref=e295]:\n                    - cell \"7\" [ref=e296]\n                    - cell \"pure music, piano solo, no lyrics\" [ref=e297]\n                    - cell \"钢琴独奏\" [ref=e298]\n                  - row \"8 pure music, lofi chill, no lyrics Lo-Fi轻松\" [ref=e299]:\n                    - cell \"8\" [ref=e300]\n                    - cell \"pure music, lofi chill, no lyrics\" [ref=e301]\n                    - cell \"Lo-Fi轻松\" [ref=e302]\n                  - row \"9 pure music, bookstore, no lyrics 书店\" [ref=e303]:\n                    - cell \"9\" [ref=e304]\n                    - cell \"pure music, bookstore, no lyrics\" [ref=e305]\n                    - cell \"书店\" [ref=e306]\n                  - row \"10 pure music, cafe closing time, no lyrics 咖啡馆打烊\" [ref=e307]:\n                    - cell \"10\" [ref=e308]\n                    - cell \"pure music, cafe closing time, no lyrics\" [ref=e309]\n                    - cell \"咖啡馆打烊\" [ref=e310]\n              - heading \"CLI Examples\" [level=3] [ref=e311]\n              - paragraph [ref=e312]: \"Generate pure music for coffee shop:\"\n              - code [ref=e314]: python scripts/generate_music.py \\ --lyrics \"[intro] [outro]\" \\ --prompt \"pure music, coffee shop, no lyrics\" \\ --output ./coffee_shop.mp3\n              - paragraph [ref=e315]: \"Generate rainy night atmosphere:\"\n              - code [ref=e317]: python scripts/generate_music.py \\ --lyrics \"[intro] [outro]\" \\ --prompt \"pure music, rainy night, no lyrics\" \\ --output ./rainy_night.mp3\n              - paragraph [ref=e318]: \"Generate piano solo:\"\n              - code [ref=e320]: python scripts/generate_music.py \\ --lyrics \"[intro] [outro]\" \\ --prompt \"pure music, piano solo, no lyrics\" \\ --output ./piano_solo.mp3\n              - separator [ref=e321]\n              - heading \"Melodic Chanting/Humming Generation\" [level=2] [ref=e322]\n              - paragraph [ref=e323]:\n                - text: Use this mode when user wants music with\n                - strong [ref=e324]: vocal syllables\n                - text: instead of full lyrics (humming, chanting).\n              - heading \"Detection Keywords\" [level=3] [ref=e325]\n              - list [ref=e326]:\n                - listitem [ref=e327]: Humming, chanting, vocalizing\n                - listitem [ref=e328]: humming、chanting\n                - listitem [ref=e329]: Healing, vocal accompaniment\n                - listitem [ref=e330]: Melodic\n                - listitem [ref=e331]: Harmony, ooh ah la\n              - heading \"Prompt Format\" [level=3] [ref=e332]\n              - code [ref=e334]: pure music, [风格/场景描述], no lyrics\n              - heading \"Lyrics Field (Syllable Patterns)\" [level=3] [ref=e335]\n              - paragraph [ref=e336]: \"Use vocal syllables instead of words:\"\n              - table [ref=e337]:\n                - rowgroup [ref=e338]:\n                  - row \"Syllable Pattern Vibe\" [ref=e339]:\n                    - columnheader \"Syllable Pattern\" [ref=e340]\n                    - columnheader \"Vibe\" [ref=e341]\n                - rowgroup [ref=e342]:\n                  - row \"ah, ah, ah, ah... 柔和吟唱\" [ref=e343]:\n                    - cell \"ah, ah, ah, ah...\" [ref=e344]:\n                      - code [ref=e345]: ah, ah, ah, ah...\n                    - cell \"柔和吟唱\" [ref=e346]\n                  - row \"la, la, la, la... 旋律哼唱\" [ref=e347]:\n                    - cell \"la, la, la, la...\" [ref=e348]:\n                      - code [ref=e349]: la, la, la, la...\n                    - cell \"旋律哼唱\" [ref=e350]\n                  - row \"mmm, mmm, mmm... 治愈系哼鸣\" [ref=e351]:\n                    - cell \"mmm, mmm, mmm...\" [ref=e352]:\n                      - code [ref=e353]: mmm, mmm, mmm...\n                    - cell \"治愈系哼鸣\" [ref=e354]\n                  - row \"ooh, ooh, ooh... 空灵吟唱\" [ref=e355]:\n                    - cell \"ooh, ooh, ooh...\" [ref=e356]:\n                      - code [ref=e357]: ooh, ooh, ooh...\n                    - cell \"空灵吟唱\" [ref=e358]\n                  - row \"hum, hum, hum... 持续哼唱\" [ref=e359]:\n                    - cell \"hum, hum, hum...\" [ref=e360]:\n                      - code [ref=e361]: hum, hum, hum...\n                    - cell \"持续哼唱\" [ref=e362]\n              - heading \"Lyrics Structure Template\" [level=3] [ref=e363]\n              - code [ref=e365]: \"[intro] [verse] [chorus] [verse] [outro]\"\n              - paragraph [ref=e366]: Replace sections with chosen syllables.\n              - heading \"Chanting Prompt Examples\" [level=3] [ref=e367]\n              - table [ref=e368]:\n                - rowgroup [ref=e369]:\n                  - row \"Scene Prompt Lyrics\" [ref=e370]:\n                    - columnheader \"Scene\" [ref=e371]\n                    - columnheader \"Prompt\" [ref=e372]\n                    - columnheader \"Lyrics\" [ref=e373]\n                - rowgroup [ref=e374]:\n                  - row \"Healing pure music, healing, relaxing, no lyrics [intro] mmm, mmm, mmm... [verse] mmm, mmm, mmm... [outro]\" [ref=e375]:\n                    - cell \"Healing\" [ref=e376]\n                    - cell \"pure music, healing, relaxing, no lyrics\" [ref=e377]\n                    - cell \"[intro] mmm, mmm, mmm... [verse] mmm, mmm, mmm... [outro]\" [ref=e378]:\n                      - code [ref=e379]: \"[intro] mmm, mmm, mmm... [verse] mmm, mmm, mmm... [outro]\"\n                  - row \"Meditation pure music, meditation, calming, no lyrics [intro] ooh, ooh, ooh... [verse] ooh, ooh, ooh... [outro]\" [ref=e380]:\n                    - cell \"Meditation\" [ref=e381]\n                    - cell \"pure music, meditation, calming, no lyrics\" [ref=e382]\n                    - cell \"[intro] ooh, ooh, ooh... [verse] ooh, ooh, ooh... [outro]\" [ref=e383]:\n                      - code [ref=e384]: \"[intro] ooh, ooh, ooh... [verse] ooh, ooh, ooh... [outro]\"\n                  - row \"Happy pure music, happy, uplifting, no lyrics [intro] la, la, la, la... [chorus] la, la, la, la... [outro]\" [ref=e385]:\n                    - cell \"Happy\" [ref=e386]\n                    - cell \"pure music, happy, uplifting, no lyrics\" [ref=e387]\n                    - cell \"[intro] la, la, la, la... [chorus] la, la, la, la... [outro]\" [ref=e388]:\n                      - code [ref=e389]: \"[intro] la, la, la, la... [chorus] la, la, la, la... [outro]\"\n                  - row \"Mystical pure music, mystical, ethereal, no lyrics [intro] ah, ah, ah... [verse] ah, ah, ah... [outro]\" [ref=e390]:\n                    - cell \"Mystical\" [ref=e391]\n                    - cell \"pure music, mystical, ethereal, no lyrics\" [ref=e392]\n                    - cell \"[intro] ah, ah, ah... [verse] ah, ah, ah... [outro]\" [ref=e393]:\n                      - code [ref=e394]: \"[intro] ah, ah, ah... [verse] ah, ah, ah... [outro]\"\n              - heading \"CLI Examples\" [level=3] [ref=e395]\n              - paragraph [ref=e396]: \"Generate healing chant music:\"\n              - code [ref=e398]: python scripts/generate_music.py \\ --lyrics \"[intro] mmm, mmm, mmm... [verse] mmm, mmm, mmm... [chorus] mmm, mmm, mmm... [outro]\" \\ --prompt \"pure music, healing, relaxing, no lyrics\" \\ --output ./healing_chant.mp3\n              - paragraph [ref=e399]: \"Generate meditation chant:\"\n              - code [ref=e401]: python scripts/generate_music.py \\ --lyrics \"[intro] ooh, ooh, ooh... [verse] ooh, ooh, ooh... [outro]\" \\ --prompt \"pure music, meditation, calming, no lyrics\" \\ --output ./meditation.mp3\n              - paragraph [ref=e402]: \"Generate happy humming:\"\n              - code [ref=e404]: python scripts/generate_music.py \\ --lyrics \"[intro] la, la, la... [verse] la, la, la... [chorus] la, la, la... [outro]\" \\ --prompt \"pure music, happy, uplifting, no lyrics\" \\ --output ./happy_humming.mp3\n              - separator [ref=e405]\n              - heading \"Mode Detection Logic\" [level=2] [ref=e406]\n              - paragraph [ref=e407]: \"When user requests music, detect the mode:\"\n              - list [ref=e408]:\n                - listitem [ref=e409]:\n                  - strong [ref=e410]: Standard Song\n                  - text: → User provides lyrics OR asks for \"song with lyrics\"\n                - listitem [ref=e411]:\n                  - strong [ref=e412]: Pure Music\n                  - text: \"→ Keywords: \\\"纯音乐\\\", \\\"pure music\\\", \\\"instrumental\\\", \\\"no lyrics\\\", \\\"无人声\\\"\"\n                - listitem [ref=e413]:\n                  - strong [ref=e414]: Chanting/Humming\n                  - text: \"→ Keywords: \\\"哼唱\\\", \\\"吟唱\\\", \\\"humming\\\", \\\"chanting\\\", \\\"治愈系\\\"\"\n              - heading \"Decision Flow\" [level=3] [ref=e415]\n              - code [ref=e417]: User Request ↓ Contains \"纯音乐\"/\"pure music\"/\"instrumental\"? ├─ Yes → Is \"哼唱\"/\"humming\" also mentioned? │ ├─ Yes → Melodic Chanting Mode │ └─ No → Pure Music Mode └─ No → Standard Song Mode (requires lyrics)\n              - heading \"Recommended CLI patterns\" [level=2] [ref=e418]\n              - paragraph [ref=e419]: \"Generate MP3 (hex response → file):\"\n              - code [ref=e421]: python scripts/generate_music.py \\ --lyrics \"[Intro]\\n...\" \\ --prompt \"cinematic, uplifting\" \\ --output ./music.mp3 \\ --format mp3 \\ --bitrate 256000 \\ --sample-rate 44100\n              - paragraph [ref=e422]: \"Generate with structured prompt fields (auto-build):\"\n              - code [ref=e424]: python scripts/generate_music.py \\ --lyrics \"[Verse]\\n...\" \\ --genre \"1980s synthwave\" \\ --mood \"nostalgic, energetic\" \\ --bpm 120 \\ --instruments \"analog synths, drum machine, bass guitar\" \\ --vocals \"female vocals\" \\ --use-case \"retro game trailer\" \\ --avoid \"no acoustic guitar\" \\ --references \"The Midnight, FM-84\" \\ --output ./music.mp3\n              - paragraph [ref=e425]: \"Generate and download from URL:\"\n              - code [ref=e427]: python scripts/generate_music.py \\ --lyrics \"[Verse]\\n...\" \\ --prompt \"lofi, rainy night\" \\ --output ./music.mp3 \\ --output-format url \\ --download\n              - separator [ref=e428]\n              - heading \"API Reference\" [level=2] [ref=e429]\n              - paragraph [ref=e430]: \"For detailed API documentation (endpoints, authentication, request/response formats), see:\"\n              - paragraph [ref=e431]:\n                - strong [ref=e432]:\n                  - code [ref=e433]: references/minimax_music_api.md\n              - paragraph [ref=e434]: \"Key points for all modes:\"\n              - list [ref=e435]:\n                - listitem [ref=e436]:\n                  - strong [ref=e437]: Endpoint\n                  - text: \":\"\n                  - code [ref=e438]: POST https://api.minimaxi.com/v1/music_generation\n                - listitem [ref=e439]:\n                  - strong [ref=e440]: Auth\n                  - text: \":\"\n                  - code [ref=e441]: \"Authorization: Bearer <token>\"\n                - listitem [ref=e442]:\n                  - strong [ref=e443]: Model\n                  - text: \":\"\n                  - code [ref=e444]: music-2.5\n                - listitem [ref=e445]:\n                  - strong [ref=e446]: lyrics\n                  - text: \": Required field - use\"\n                  - code [ref=e447]: \"[intro] [outro]\"\n                  - text: for pure music, or syllable patterns for chanting\n              - heading \"Quick API Payload Examples\" [level=3] [ref=e448]\n              - paragraph [ref=e449]:\n                - strong [ref=e450]: \"Standard Song:\"\n              - code [ref=e452]: \"{ \\\"model\\\": \\\"music-2.5\\\", \\\"prompt\\\": \\\"indie folk, melancholic, introspective\\\", \\\"lyrics\\\": \\\"[verse]\\\\n...\\\\n[chorus]\\\\n...\\\" }\"\n              - paragraph [ref=e453]:\n                - strong [ref=e454]: \"Pure Music:\"\n              - code [ref=e456]: \"{ \\\"model\\\": \\\"music-2.5\\\", \\\"prompt\\\": \\\"pure music, coffee shop, no lyrics\\\", \\\"lyrics\\\": \\\"[intro] [outro]\\\" }\"\n              - paragraph [ref=e457]:\n                - strong [ref=e458]: \"Melodic Chanting:\"\n              - code [ref=e460]: \"{ \\\"model\\\": \\\"music-2.5\\\", \\\"prompt\\\": \\\"pure music, healing, relaxing, no lyrics\\\", \\\"lyrics\\\": \\\"[intro] mmm, mmm, mmm... [verse] mmm, mmm, mmm... [outro]\\\" }\"\n              - heading \"Response Format\" [level=3] [ref=e461]\n              - list [ref=e462]:\n                - listitem [ref=e463]:\n                  - code [ref=e464]: data.audio\n                  - text: \": hex string (default) or URL (valid 24 hours)\"\n                - listitem [ref=e465]:\n                  - code [ref=e466]: data.status\n                  - text: \": generation status\"\n                - listitem [ref=e467]:\n                  - code [ref=e468]: extra_info\n                  - text: \": duration, sample rate, channels, bitrate, size\"\n                - l