mand":"openclaw doctor","workdir":"/Users/suchuanlei/.openclaw/workspace","yieldMs":15000,"timeout":120},"partialJson":"{\"command\":\"openclaw doctor\",\"workdir\":\"/Users/suchuanlei/.openclaw/workspace\",\"yieldMs\":15000,\"timeout\":120}"},{"type":"toolCall","id":"call_vtqQoNj0JwgpJfpNXxAbRBQe|fc_0a9d9f33739773480169ae7d1857048191a5f92786400d81a4","name":"exec","arguments":{"command":"ls -lt ~/.openclaw/logs | head -20","workdir":"/Users/suchuanlei/.openclaw/workspace"},"partialJson":"{\"command\":\"ls -lt ~/.openclaw/logs | head -20\",\"workdir\":\"/Users/suchuanlei/.openclaw/workspace\"}"},{"type":"toolCall","id":"call_lYbOSheexPfj7IufCQMpMfi2|fc_0a9d9f33739773480169ae7d18570c8191bce40c2d4422b83d","name":"exec","arguments":{"command":"grep -RniE \"feishu|lark|oauth|announce delivery failed|heartbeat|Unknown target|token_expired|unauthorized|forbidden\" ~/.openclaw/logs 2>/dev/null | tail -200","workdir":"/Users/suchuanlei/.openclaw/workspace","yieldMs":15000,"timeout":120},"partialJson":"{\"command\":\"grep -RniE \\\"feishu|lark|oauth|announce delivery failed|heartbeat|Unknown target|token_expired|unauthorized|forbidden\\\" ~/.openclaw/logs 2>/dev/null | tail -200\",\"workdir\":\"/Users/suchuanlei/.openclaw/workspace\",\"yieldMs\":15000,\"timeout\":120}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.4","usage":{"input":1433,"output":329,"cacheRead":93312,"cacheWrite":0,"totalTokens":95074,"cost":{"input":0.00250775,"output":0.004606,"cacheRead":0.0163296,"cacheWrite":0,"total":0.02344335}},"stopReason":"toolUse","timestamp":1773042957824}}
