{"type":"message","id":"b4f295cd","parentId":"784f2f8d","timestamp":"2026-03-06T23:56:51.636Z","message":{"role":"assistant","content":[{"type":"text","text":"好！苏神，本王这就把 Tavily 的 API Key 配置上。"},{"type":"toolCall","id":"call_mddu4us8rs0e5e92tplelawt","name":"exec","arguments":{"command":"openclaw config set skills.tavily-search.apiKey \"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\"","timeout":30000}}],"api":"openai-completions","provider":"volcengine-plan","model":"ark-code-latest","usage":{"input":20386,"output":104,"cacheRead":29496,"cacheWrite":0,"totalTokens":49986,"cost":{"input":0.0000020386000000000003,"output":2.08e-8,"cacheRead":0,"cacheWrite":0,"total":0.0000020594}},"stopReason":"toolUse","timestamp":1772841397542}}
