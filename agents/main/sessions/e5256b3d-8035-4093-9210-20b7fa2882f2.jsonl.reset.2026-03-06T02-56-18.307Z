{"type":"message","id":"5fb3ce7e","parentId":"b8a727fb","timestamp":"2026-03-06T02:39:00.966Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"toolu_bdrk_018Hwo33pG5YMpMqozBKbtVC","name":"write","arguments":{"path":"/Users/suchuanlei/.openclaw/workspace/scripts/nightly-security-audit.sh","content":"#!/bin/bash\n# ============================================================\n# OpenClaw 每日安全巡检脚本 (macOS 适配版)\n# 基于慢雾安全团队 OpenClaw 极简安全实践指南 v2.7\n# ============================================================\n\nset -euo pipefail\n\nOC=\"${OPENCLAW_STATE_DIR:-$HOME/.openclaw}\"\nREPORT_DIR=\"/tmp/openclaw/security-reports\"\nDATE=$(date +%Y-%m-%d)\nTIME=$(date +%H:%M:%S)\nREPORT_FILE=\"$REPORT_DIR/report-$DATE.txt\"\n\nmkdir -p \"$REPORT_DIR\"\n\n# 颜色（仅终端显示用）\nRED='\\033[0;31m'\nYEL='\\033[1;33m'\nGRN='\\033[0;32m'\nNC='\\033[0m'\n\nSUMMARY=\"\"\nDETAILS=\"\"\nALERT_COUNT=0\nWARN_COUNT=0\n\nok()   { SUMMARY+=\"✅ $1\\n\"; }\nwarn() { SUMMARY+=\"⚠️ $1\\n\"; ((WARN_COUNT++)) || true; }\nalert(){ SUMMARY+=\"🚨 $1\\n\"; ((ALERT_COUNT++)) || true; }\ndetail(){ DETAILS+=\"$1\\n\"; }\n\ndetail \"==========================================\"\ndetail \"OpenClaw 安全巡检详细报告 $DATE $TIME\"\ndetail \"==========================================\"\n\n# ─────────────────────────────────────────────\n# 1. OpenClaw 平台安全审计\n# ─────────────────────────────────────────────\ndetail \"\\n--- [1] OpenClaw 平台安全审计 ---\"\nOC_AUDIT=$(openclaw security audit --deep 2>&1 || true)\ndetail \"$OC_AUDIT\"\n\nif echo \"$OC_AUDIT\" | grep -qi \"critical\"; then\n    warn \"1. 平台审计: 存在 CRITICAL 级告警（详见报告）\"\nelse\n    ok \"1. 平台审计: 已执行原生深度扫描，无 CRITICAL 告警\"\nfi\n\n# ─────────────────────────────────────────────\n# 2. 进程与网络审计\n# ─────────────────────────────────────────────\ndetail \"\\n--- [2] 进程与网络审计 ---\"\n\n# 监听端口\nLISTEN=$(lsof -i -P -n 2>/dev/null | grep LISTEN || true)\ndetail \"监听端口:\\n$LISTEN\"\n\n# Top 15 高资源进程\nTOP15=$(ps aux --sort=-%mem 2>/dev/null | head -16 || ps aux | sort -nrk 4 | head -16)\ndetail \"\\nTop 15 内存占用:\\n$TOP15\"\n\n# 异常出站连接（排除 localhost 和常见端口）\nOUTBOUND=$(lsof -i -P -n 2>/dev/null | grep ESTABLISHED | grep -v \"127.0.0.1\\|::1\" || true)\ndetail \"\\n出站连接:\\n$OUTBOUND\"\n\nOUTBOUND_COUNT=$(echo \"$OUTBOUND\" | grep -c . 2>/dev/null || echo 0)\nif [ \"$OUTBOUND_COUNT\" -gt 20 ]; then\n    warn \"2. 进程网络: $OUTBOUND_COUNT 个活跃出站连接（偏多，请检查）\"\nelse\n    ok \"2. 进程网络: $OUTBOUND_COUNT 个出站连接，监听端口已记录\"\nfi\n\n# ─────────────────────────────────────────────\n# 3. 敏感目录变更（最近 24h）\n# ─────────────────────────────────────────────\ndetail \"\\n--- [3] 敏感目录变更 ---\"\n\nCHANGED_FILES=\"\"\nfor DIR in \"$OC/\" \"$HOME/.ssh/\" \"/etc/\" \"/usr/local/bin/\"; do\n    if [ -d \"$DIR\" ]; then\n        FOUND=$(find \"$DIR\" -type f -mtime -1 2>/dev/null | head -50 || true)\n        if [ -n \"$FOUND\" ]; then\n            CHANGED_FILES+=\"$FOUND\\n\"\n        fi\n    fi\ndone\ndetail \"$CHANGED_FILES\"\n\nCHANGED_COUNT=$(echo -e \"$CHANGED_FILES\" | grep -c . 2>/dev/null || echo 0)\nif [ \"$CHANGED_COUNT\" -gt 0 ]; then\n    warn \"3. 目录变更: $CHANGED_COUNT 个文件在过去 24h 内变更\"\nelse\n    ok \"3. 目录变更: 敏感目录无文件变更\"\nfi\n\n# ─────────────────────────────────────────────\n# 4. 系统定时任务\n# ─────────────────────────────────────────────\ndetail \"\\n--- [4] 系统定时任务 ---\"\n\n# 用户 crontab\nUSER_CRON=$(crontab -l 2>/dev/null || echo \"(无用户 crontab)\")\ndetail \"用户 crontab:\\n$USER_CRON\"\n\n# LaunchAgents / LaunchDaemons\nLA_USER=$(ls ~/Library/LaunchAgents/ 2>/dev/null || echo \"(空)\")\nLA_SYS=$(ls /Library/LaunchAgents/ 2>/dev/null || echo \"(空)\")\nLD_SYS=$(ls /Library/LaunchDaemons/ 2>/dev/null || echo \"(空)\")\ndetail \"\\n用户 LaunchAgents:\\n$LA_USER\"\ndetail \"\\n系统 LaunchAgents:\\n$LA_SYS\"\ndetail \"\\n系统 LaunchDaemons:\\n$LD_SYS\"\n\n# 检查可疑 plist（指向外部 URL 的）\nSUSPICIOUS_PLIST=$(grep -rl \"curl\\|wget\\|http://\" ~/Library/LaunchAgents/ /Library/LaunchAgents/ /Library/LaunchDaemons/ 2>/dev/null || true)\nif [ -n \"$SUSPICIOUS_PLIST\" ]; then\n    alert \"4. 系统任务: 发现可疑 plist 引用外部 URL: $SUSPICIOUS_PLIST\"\nelse\n    ok \"4. 系统任务: 未发现可疑系统级定时任务\"\nfi\n\n# ─────────────────────────────────────────────\n# 5. OpenClaw Cron Jobs\n# ─────────────────────────────────────────────\ndetail \"\\n--- [5] OpenClaw Cron Jobs ---\"\nOC_CRON=$(openclaw cron list 2>&1 || echo \"(无法获取)\")\ndetail \"$OC_CRON\"\nok \"5. 本地 Cron: 已列出 OpenClaw 内部任务（详见报告）\"\n\n# ─────────────────────────────────────────────\n# 6. 登录与 SSH 安全\n# ─────────────────────────────────────────────\ndetail \"\\n--- [6] 登录与 SSH 安全 ---\"\n\n# macOS 用 log show 查 SSH\nSSH_FAIL=$(log show --predicate 'process == \"sshd\" AND eventMessage CONTAINS \"Failed\"' --last 24h --style compact 2>/dev/null | tail -20 || echo \"(无法获取或无 SSH 失败记录)\")\ndetail \"SSH 失败尝试 (24h):\\n$SSH_FAIL\"\n\nLAST_LOGIN=$(last -10 2>/dev/null || echo \"(无法获取)\")\ndetail \"\\n最近登录:\\n$LAST_LOGIN\"\n\nSSH_FAIL_COUNT=$(echo \"$SSH_FAIL\" | grep -c \"Failed\" 2>/dev/null || echo 0)\nif [ \"$SSH_FAIL_COUNT\" -gt 10 ]; then\n    warn \"6. SSH 安全: $SSH_FAIL_COUNT 次失败尝试（可能遭遇爆破）\"\nelse\n    ok \"6. SSH 安全: $SSH_FAIL_COUNT 次失败尝试\"\nfi\n\n# ─────────────────────────────────────────────\n# 7. 关键文件完整性\n# ─────────────────────────────────────────────\ndetail \"\\n--- [7] 关键文件完整性 ---\"\n\nBASELINE_FILE=\"$OC/.config-baseline.sha256\"\nif [ -f \"$BASELINE_FILE\" ]; then\n    HASH_CHECK=$(cd / && shasum -a 256 -c \"$BASELINE_FILE\" 2>&1 || true)\n    detail \"哈希校验:\\n$HASH_CHECK\"\n    if echo \"$HASH_CHECK\" | grep -q \"FAILED\"; then\n        alert \"7. 配置基线: 哈希校验失败！核心配置文件可能被篡改\"\n    else\n        ok \"7. 配置基线: SHA256 哈希校验通过\"\n    fi\nelse\n    warn \"7. 配置基线: 基线文件不存在，无法校验\"\nfi\n\n# 权限检查\ndetail \"\\n权限检查:\"\nfor F in \"$OC/openclaw.json\" \"$OC/devices/paired.json\" \"$HOME/.ssh/authorized_keys\"; do\n    if [ -f \"$F\" ]; then\n        PERM=$(stat -f \"%Sp %OLp\" \"$F\" 2>/dev/null || true)\n        detail \"  $F → $PERM\"\n        if echo \"$PERM\" | grep -qv \"600\\|400\"; then\n            warn \"7+. 权限异常: $F 权限为 $PERM（预期 600）\"\n        fi\n    fi\ndone\n\n# ─────────────────────────────────────────────\n# 8. 黄线操作交叉验证\n# ─────────────────────────────────────────────\ndetail \"\\n--- [8] 黄线操作交叉验证 ---\"\n\n# macOS 查 sudo 记录\nSUDO_LOG=$(log show --predicate 'process == \"sudo\"' --last 24h --style compact 2>/dev/null | tail -30 || echo \"(无法获取)\")\ndetail \"sudo 记录 (24h):\\n$SUDO_LOG\"\n\nSUDO_COUNT=$(echo \"$SUDO_LOG\" | grep -c \"sudo\" 2>/dev/null || echo 0)\nMEMORY_FILE=\"$OC/workspace/memory/$DATE.md\"\nif [ -f \"$MEMORY_FILE\" ]; then\n    MEMORY_SUDO=$(grep -ci \"sudo\\|黄线\" \"$MEMORY_FILE\" 2>/dev/null || echo 0)\n    detail \"\\nmemory 日志中黄线记录数: $MEMORY_SUDO\"\n    ok \"8. 黄线审计: $SUDO_COUNT 次 sudo 记录（memory 日志已比对）\"\nelse\n    if [ \"$SUDO_COUNT\" -gt 0 ]; then\n        warn \"8. 黄线审计: 发现 $SUDO_COUNT 次 sudo 但无当日 memory 日志\"\n    else\n        ok \"8. 黄线审计: 无 sudo 记录\"\n    fi\nfi\n\n# ─────────────────────────────────────────────\n# 9. 磁盘使用\n# ─────────────────────────────────────────────\ndetail \"\\n--- [9] 磁盘使用 ---\"\n\nDISK_USAGE=$(df -h / 2>/dev/null | tail -1)\ndetail \"根分区: $DISK_USAGE\"\nDISK_PCT=$(echo \"$DISK_USAGE\" | awk '{gsub(/%/,\"\",$5); print $5}' 2>/dev/null || echo 0)\n\n# 最近 24h 新增大文件 (>100MB)\nBIG_FILES=$(find / -type f -size +100M -mtime -1 2>/dev/null | grep -v \"/System\\|/Library/Apple\\|/private/var/db\" | head -20 || true)\ndetail \"\\n新增大文件 (>100MB, 24h):\\n${BIG_FILES:-无}\"\n\nBIG_COUNT=$(echo \"$BIG_FILES\" | grep -c . 2>/dev/null || echo 0)\nif [ \"$DISK_PCT\" -gt 85 ]; then\n    warn \"9. 磁盘容量: 根分区占用 ${DISK_PCT}%（>85% 告警），$BIG_COUNT 个大文件\"\nelse\n    ok \"9. 磁盘容量: 根分区占用 ${DISK_PCT}%，新增 $BIG_COUNT 个大文件\"\nfi\n\n# ─────────────────────────────────────────────\n# 10. Gateway 环境变量\n# ─────────────────────────────────────────────\ndetail \"\\n--- [10] Gateway 环境变量 ---\"\n\nGW_PID=$(pgrep -f \"openclaw.*gateway\" 2>/dev/null | head -1 || true)\nif [ -n \"$GW_PID\" ]; then\n    # macOS 用 ps eww 获取环境变量\n    GW_ENV=$(ps eww -p \"$GW_PID\" 2>/dev/null || true)\n    SENSITIVE_VARS=$(echo \"$GW_ENV\" | tr ' ' '\\n' | grep -iE \"KEY=|TOKEN=|SECRET=|PASSWORD=|PRIVATE=\" | sed 's/=.*/=***/' || true)\n    detail \"含敏感关键字的变量名:\\n${SENSITIVE_VARS:-无}\"\n    ok \"10. 环境变量: Gateway PID=$GW_PID，敏感变量已脱敏列出\"\nelse\n    warn \"10. 环境变量: 未找到 Gateway 进程\"\nfi\n\n# ─────────────────────────────────────────────\n# 11. 明文私钥/凭证泄露扫描 (DLP)\n# ─────────────────────────────────────────────\ndetail \"\\n--- [11] DLP 扫描 ---\"\n\nDLP_HITS=\"\"\n# 扫描 workspace 目录（尤其 memory 和 logs）\nfor SCAN_DIR in \"$OC/workspace/memory\" \"$OC/workspace\" \"$OC/agents\"; do\n    if [ -d \"$SCAN_DIR\" ]; then\n        # 以太坊私钥格式 (0x + 64 hex)\n        ETH_KEYS=$(grep -rlE \"0x[0-9a-fA-F]{64}\" \"$SCAN_DIR\" 2>/dev/null | head -5 || true)\n        # 助记词 (12/24 个英文单词序列的常见模式)\n        MNEMONIC=$(grep -rlE \"(abandon|ability|able|about|above|absent|absorb|abstract|absurd|abuse)\" \"$SCAN_DIR\" 2>/dev/null | head -5 || true)\n        # 明文 API key 模式\n        API_KEYS=$(grep -rlEi \"(sk-[a-zA-Z0-9]{20,}|ghp_[a-zA-Z0-9]{36}|AKIA[0-9A-Z]{16})\" \"$SCAN_DIR\" 2>/dev/null | head -5 || true)\n\n        if [ -n \"$ETH_KEYS\" ]; then DLP_HITS+=\"可能的私钥: $ETH_KEYS\\n\"; fi\n        if [ -n \"$MNEMONIC\" ]; then DLP_HITS+=\"可能的助记词: $MNEMONIC\\n\"; fi\n        if [ -n \"$API_KEYS\" ]; then DLP_HITS+=\"可能的 API Key: $API_KEYS\\n\"; fi\n    fi\ndone\n\ndetail \"${DLP_HITS:-无发现}\"\nif [ -n \"$DLP_HITS\" ]; then\n    alert \"11. DLP 扫描: 发现可能的明文凭证泄露（详见报告）\"\nelse\n    ok \"11. DLP 扫描: workspace 未发现明文私钥或助记词\"\nfi\n\n# ─────────────────────────────────────────────\n# 12. Skill/MCP 完整性\n# ─────────────────────────────────────────────\ndetail \"\\n--- [12] Skill/MCP 完整性 ---\"\n\nSKILL_BASELINE=\"$OC/.skill-baseline.sha256\"\nSKILL_DIR=\"$HOME/.agents/skills\"\nSYSTEM_SKILL_DIR=\"$HOME/.npm-global/lib/node_modules/openclaw/skills\"\n\nCURRENT_HASHES=\"\"\nfor SD in \"$SKILL_DIR\" \"$SYSTEM_SKILL_DIR\"; do\n    if [ -d \"$SD\" ]; then\n        HASHES=$(find \"$SD\" -type f \\( -name \"*.sh\" -o -name \"*.js\" -o -name \"*.py\" -o -name \"*.md\" -o -name \"*.json\" \\) -exec shasum -a 256 {} \\; 2>/dev/null || true)\n        CURRENT_HASHES+=\"$HASHES\\n\"\n    fi\ndone\n\nif [ -f \"$SKILL_BASELINE\" ]; then\n    echo -e \"$CURRENT_HASHES\" > /tmp/openclaw/skill-current.sha256\n    SKILL_DIFF=$(diff \"$SKILL_BASELINE\" /tmp/openclaw/skill-current.sha256 2>/dev/null || true)\n    detail \"${SKILL_DIFF:-无变化}\"\n    if [ -n \"$SKILL_DIFF\" ]; then\n        warn \"12. Skill 基线: 检测到 Skill 文件变更（详见报告）\"\n    else\n        ok \"12. Skill 基线: 所有 Skill 文件哈希一致\"\n    fi\nelse\n    # 首次运行，生成基线\n    echo -e \"$CURRENT_HASHES\" > \"$SKILL_BASELINE\"\n    detail \"首次运行，已生成 Skill 哈希基线\"\n    ok \"12. Skill 基线: 首次运行，已生成基线文件\"\nfi\n\n# ─────────────────────────────────────────────\n# 13. 灾备状态（Git 备份 - 可选）\n# ─────────────────────────────────────────────\ndetail \"\\n--- [13] 灾备状态 ---\"\n\nif [ -d \"$OC/.git\" ]; then\n    GIT_STATUS=$(cd \"$OC\" && git status --porcelain 2>/dev/null || true)\n    GIT_REMOTE=$(cd \"$OC\" && git remote -v 2>/dev/null || true)\n    detail \"Git status:\\n$GIT_STATUS\"\n    detail \"Git remote:\\n$GIT_REMOTE\"\n    ok \"13. 灾备备份: Git 仓库已配置\"\nelse\n    warn \"13. 灾备备份: 未配置 Git 仓库（可选，后续可补）\"\nfi\n\n# ─────────────────────────────────────────────\n# 输出汇总\n# ─────────────────────────────────────────────\n\nHEADER=\"🛡️ OpenClaw 每日安全巡检简报 ($DATE $TIME)\"\n\nif [ \"$ALERT_COUNT\" -gt 0 ]; then\n    STATUS=\"🚨 发现 $ALERT_COUNT 个高危告警 + $WARN_COUNT 个警告\"\nelif [ \"$WARN_COUNT\" -gt 0 ]; then\n    STATUS=\"⚠️ 发现 $WARN_COUNT 个警告，无高危\"\nelse\n    STATUS=\"✅ 全部通过，系统安全\"\nfi\n\nOUTPUT=\"$HEADER\\n$STATUS\\n\\n$SUMMARY\\n📝 详细战报已保存: $REPORT_FILE\"\n\n# 写入详细报告\necho -e \"$DETAILS\" > \"$REPORT_FILE\"\n\n# 输出摘要（供 cron announce 推送）\necho -e \"$OUTPUT\"\n"}}],"api":"openai-completions","provider":"openrouter","model":"anthropic/claude-opus-4.6","usage":{"input":3383,"output":5296,"cacheRead":30139,"cacheWrite":0,"totalTokens":38818,"cost":{"input":0.016915000000000003,"output":0.13240000000000002,"cacheRead":0.0150695,"cacheWrite":0,"total":0.16438450000000004}},"stopReason":"toolUse","timestamp":1772764664422}}
